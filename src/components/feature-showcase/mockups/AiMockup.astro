---
import type { Locale } from '../../../i18n/ui';
import { getDir } from '../../../i18n/ui';
import { getFeatureMockupCopy } from '../../../i18n/featureMockups';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = getFeatureMockupCopy(locale).ai;
const dir = getDir(locale);
---

<div class="fs-mockup-inner h-full min-h-[380px] sm:min-h-[440px]" dir={dir}>
  <div class="flex h-full flex-col">
    <div class="fs-ai-header">
      <div class="flex items-center gap-2.5">
        <div class="fs-ai-icon" aria-hidden="true">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/><path d="M2 14h2"/><path d="M20 14h2"/><path d="M15 13v2"/><path d="M9 13v2"/></svg>
        </div>
        <div>
          <div class="fs-ai-title">{m.title}</div>
          <div class="fs-ai-status"><span class="fs-ai-dot"></span> {m.status}</div>
        </div>
      </div>
      <div class="fs-ai-badge">{m.badge}</div>
    </div>

    <div class="fs-ai-chat">
      <div class="fs-ai-msg fs-ai-msg--bot">
        <div class="fs-ai-avatar" aria-hidden="true">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/></svg>
        </div>
        <div class="fs-ai-bubble fs-ai-bubble--bot">
          <p>{m.greeting}</p>
        </div>
      </div>

      <div class="fs-ai-suggestions">
        {m.suggestions.map((s) => (
          <span class="fs-ai-chip">{s}</span>
        ))}
      </div>

      <div class="fs-ai-msg fs-ai-msg--user">
        <div class="fs-ai-user-avatar" aria-hidden="true"></div>
        <div class="fs-ai-bubble fs-ai-bubble--user">
          <p>{m.userQuery}</p>
        </div>
      </div>

      <div class="fs-ai-msg fs-ai-msg--bot">
        <div class="fs-ai-avatar" aria-hidden="true">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2"><path d="M12 8V4H8"/><rect width="16" height="12" x="4" y="8" rx="2"/></svg>
        </div>
        <div class="fs-ai-bubble fs-ai-bubble--bot">
          <p class="fs-ai-response-intro" set:html={m.responseIntro} />
          <div class="fs-ai-appointments">
            {m.appointments.map((a) => (
              <div
                class:list={['fs-ai-appt', a.pending && 'fs-ai-appt--pending']}
                style={`border-right-color:${a.pending ? '#f59e0b' : '#0037b0'}`}
              >
                <span class="fs-ai-appt-time" style={`color:${a.pending ? '#f59e0b' : '#0037b0'}`}>{a.time}</span>
                <div>
                  <div class="fs-ai-appt-name">{a.name}</div>
                  <div class="fs-ai-appt-type">{a.type}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div class="fs-ai-input-bar">
      <div class="fs-ai-input">{m.inputPlaceholder}</div>
      <div class="fs-ai-send" aria-hidden="true">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M22 2L11 13M22 2l-7 20-4-9-9-4 20-7z"/></svg>
      </div>
    </div>
  </div>
</div>
