---
import type { Locale } from '../../../i18n/ui';
import { getDir } from '../../../i18n/ui';
import { getFeatureMockupCopy } from '../../../i18n/featureMockups';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const m = getFeatureMockupCopy(locale).crm;
const dir = getDir(locale);
const statColors = [
  { color: '#0037b0', bg: '#e5eeff' },
  { color: '#16a34a', bg: '#dcfce7' },
  { color: '#d97706', bg: '#fef9c3' },
  { color: '#7c3aed', bg: '#f3e8ff' },
];
---

<div class="fs-mockup-inner h-full min-h-[380px] sm:min-h-[440px]" dir={dir}>
  <div class="flex h-full flex-col">
    <div class="fs-mockup-header">
      <div>
        <h4 class="fs-mockup-title">{m.title}</h4>
        <p class="fs-mockup-subtitle">{m.subtitle}</p>
      </div>
      <div class="flex items-center gap-2">
        <div class="fs-mockup-search">
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
          <span>{m.search}</span>
        </div>
        <div class="fs-mockup-chip fs-mockup-chip--primary">{m.addClient}</div>
      </div>
    </div>

    <div class="fs-crm-stats">
      {m.stats.map((s, i) => (
        <div class="fs-crm-stat" style={`background:${statColors[i].bg}`}>
          <div class="fs-crm-stat-val" style={`color:${statColors[i].color}`}>{s.val}</div>
          <div class="fs-crm-stat-label">{s.label}</div>
        </div>
      ))}
    </div>

    <div class="fs-crm-list">
      {m.clients.map((c) => (
        <div class="fs-crm-row">
          <div class:list={['fs-avatar fs-avatar--lg', c.sc === 'active' ? 'fs-avatar--active' : '']}>{c.init}</div>
          <div class="fs-crm-row-main">
            <div class="fs-crm-row-name">{c.name}</div>
            <div class="fs-crm-row-phone">{c.phone}</div>
          </div>
          <div class="fs-crm-row-stat">
            <div class="fs-crm-row-stat-val">{c.apps}</div>
            <div>{m.appointmentsLabel}</div>
          </div>
          <div class="fs-crm-row-last">{c.last}</div>
          <div class:list={['fs-crm-status', c.sc === 'active' ? 'fs-crm-status--active' : 'fs-crm-status--pending']}>{c.status}</div>
          <div class="fs-crm-actions" aria-hidden="true">
            <div class="fs-crm-action-btn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#0037b0" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.65 3.62 2 2 0 0 1 3.62 1.44h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <div class="fs-crm-action-btn">
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#0037b0" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>
