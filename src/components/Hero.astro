---
import type { Locale } from '../i18n/ui';
import { arrowIconClass, getMessages, isRtl } from '../i18n/ui';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);
const rtl = isRtl(locale);
---

<section id="top" class="relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 bg-hero" aria-hidden="true"></div>
  <div class="pointer-events-none absolute inset-0 grid-bg" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-5 pb-24 pt-20 sm:px-8 sm:pb-32 sm:pt-28">
    <div class="mx-auto max-w-3xl text-center">

      <h1 class="mt-6 font-display text-5xl font-extrabold leading-[1.05] tracking-tight sm:text-6xl md:text-7xl">
        <span class="text-ink">{t.hero.headlineLine1}</span><br />
        <span class="text-gradient">{t.hero.headlineLine2}</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-muted-foreground">
        {t.hero.subheadline}
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-3">
        <a href="#pricing" class="group btn-primary">
          {t.hero.primaryCta}
          {
            rtl ? (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={arrowIconClass(locale)} aria-hidden="true">
                <path d="m12 19-7-7 7-7"></path>
                <path d="M19 12H5"></path>
              </svg>
            ) : (
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class={arrowIconClass(locale)} aria-hidden="true">
                <path d="M5 12h14"></path>
                <path d="m12 5 7 7-7 7"></path>
              </svg>
            )
          }
        </a>
        <a href="#features-showcase" class="btn-secondary">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="h-4 w-4 text-primary" aria-hidden="true">
            <path d="M5 5a2 2 0 0 1 3.008-1.728l11.997 6.998a2 2 0 0 1 .003 3.458l-12 7A2 2 0 0 1 5 19z"></path>
          </svg>
          {t.hero.secondaryCta}
        </a>
      </div>

      <p class="mt-5 text-xs font-bold text-muted-foreground">{t.hero.proof}</p>
    </div>
  </div>
</section>
