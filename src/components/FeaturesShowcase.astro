---
import type { Locale } from '../i18n/ui';
import { getMessages } from '../i18n/ui';
import FeatureShowcaseItem from './feature-showcase/FeatureShowcaseItem.astro';
import WhatsAppMockup from './feature-showcase/mockups/WhatsAppMockup.astro';
import CalendarMockup from './feature-showcase/mockups/CalendarMockup.astro';
import CrmMockup from './feature-showcase/mockups/CrmMockup.astro';
import AiMockup from './feature-showcase/mockups/AiMockup.astro';
import ReportsMockup from './feature-showcase/mockups/ReportsMockup.astro';
import '../styles/section-features-showcase.css';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const t = getMessages(locale);

const features = [
  {
    id: 'feature-whatsapp',
    title: t.featuresShowcase?.whatsapp?.title || 'WhatsApp',
    description: t.featuresShowcase?.whatsapp?.description || 'Automatic reminders sent to clients via WhatsApp',
    Mockup: WhatsAppMockup,
  },
  {
    id: 'feature-calendar',
    title: t.featuresShowcase?.calendar?.title || 'Calendar',
    description: t.featuresShowcase?.calendar?.description || 'Manage your schedule and appointments easily',
    Mockup: CalendarMockup,
  },
  {
    id: 'feature-crm',
    title: t.featuresShowcase?.crm?.title || 'Client CRM',
    description: t.featuresShowcase?.crm?.description || 'Manage your client relationships and history',
    Mockup: CrmMockup,
  },
  {
    id: 'feature-reports',
    title: t.featuresShowcase?.reports?.title || 'Client reports',
    description: t.featuresShowcase?.reports?.description || 'Create and send professional client reports in one click',
    Mockup: ReportsMockup,
  },
  {
    id: 'feature-ai',
    title: t.featuresShowcase?.ai?.title || 'AI Agent',
    description: t.featuresShowcase?.ai?.description || 'AI-powered assistant available 24/7 for your business',
    Mockup: AiMockup,
  },
];
---

<section id="features-showcase" class="relative py-20 sm:py-28">
  <div class="relative mx-auto max-w-7xl px-5 sm:px-8">
    <div class="mx-auto mb-12 max-w-3xl text-center sm:mb-16">
      <h2 class="font-display text-3xl font-bold tracking-tight sm:text-4xl md:text-5xl">
        <span class="text-ink">{t.featuresShowcase?.headline || 'Everything you need'}</span>
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        {t.featuresShowcase?.subheadline || 'Powerful features to run your business smoothly'}
      </p>
    </div>

    <div class="relative mx-auto max-w-5xl space-y-0">
      {features.map(({ id, title, description, Mockup }) => (
        <FeatureShowcaseItem id={id} title={title} description={description}>
          <Mockup locale={locale} />
        </FeatureShowcaseItem>
      ))}
    </div>
  </div>
</section>
